# zmodload zsh/zprof

DOTFILES=$HOME/.dotfiles

# Support ARM64 and AMD64 macOS.
if [ $(uname -m) = "arm64" ]
then
	BREW_PATH=/opt/homebrew
else
	BREW_PATH=/usr/local
fi

# export ZSH="$HOME/.oh-my-zsh"
# ZSH_THEME="robbyrussell"

# plugins=(git)
# source $ZSH/oh-my-zsh.sh

# PATH - consolidated for performance
export PATH="$BREW_PATH/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin"

# rbenv is lazy-loaded via ruby/rbenv.zsh
eval "$(starship init zsh)"

# Special dirs
zstyle ':completion:*' special-dirs true

if [[ -a ~/.localrc ]]
then
  source ~/.localrc
fi

# all of our zsh files
typeset -U config_files
config_files=($DOTFILES/**/*.zsh)

# load the path files
for file in ${(M)config_files:#*/path.zsh}
do
  source $file
done

# load everything but the path and completion files
for file in ${${config_files:#*/path.zsh}:#*/completion.zsh}
do
  source $file
done

# Defer compinit to after prompt appears for faster startup
_deferred_compinit() {
  # Self-remove so this only runs once
  add-zsh-hook -d precmd _deferred_compinit

  autoload -Uz compinit
  if [ -f ~/.zcompdump ]; then
    zcompdump_modification_time=$(stat -f "%m" ~/.zcompdump)
    current_time=$(date +%s)
    if (( current_time - zcompdump_modification_time > 86400 )); then
      compinit
    else
      compinit -C
    fi
  else
    compinit
  fi
  
  # load every completion after autocomplete loads
  for file in ${(M)config_files:#*/completion.zsh}
  do
    source $file
  done
  
  unset config_files
}

# Run compinit after first prompt appears
autoload -Uz add-zsh-hook
add-zsh-hook precmd _deferred_compinit

export PATH="/opt/homebrew/bin:$PATH"

export USE_GKE_GCLOUD_AUTH_PLUGIN=True

export PATH="$PATH:/opt/homebrew/bin/python3.9/bin"

# zprof

# Created by `pipx` on 2024-10-28 20:02:35
export PATH="$PATH:/Users/alongat/.local/bin"
# The next line updates PATH for the Google Cloud SDK.
if [ -f '/opt/homebrew/share/google-cloud-sdk/path.zsh.inc' ]; then . '/opt/homebrew/share/google-cloud-sdk/path.zsh.inc'; fi

# gcloud completion is lazy-loaded via gcloud/completion.zsh for performance

# Lazy-load carapace completion for faster shell startup
if command -v carapace &> /dev/null; then
  carapace() {
    unfunction carapace
    source <(command carapace _carapace)
    carapace "$@"
  }
fi

# Torq AI dev tools plugin root (used by skill scripts)
export CLAUDE_PLUGIN_ROOT="/Users/alongat/Code/torqio/ai-dev-tools/claude/plugins/torq-observability"
